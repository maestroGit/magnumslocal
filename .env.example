
# Google OAuth2 (añadir tus credenciales de consola de Google)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

###############################################################
# Ejemplo de archivo .env para nodo secundario
# que se conecta al relay público y seguro en Seenode
#
# Usa este archivo como plantilla para nodos que NO actúan como relay,
# sino que se conectan a la red a través del relay principal (Seenode).
#
# Relay principal: wss://app.blockswine.com:443
###############################################################

# 🌐 Puertos del Servidor
HTTP_PORT=3000
P2P_PORT=5001

# Dirección del relay Seenode (no modificar si quieres conectarte a la red pública)
PEERS=wss://app.blockswine.com:443

# 🔑 UPnP - Apertura automática de puertos (solo para nodos locales)
# Activa la apertura automática de puertos en el router mediante UPnP
# true = intentará abrir el puerto P2P_PORT automáticamente
# false = no usará UPnP (el nodo funcionará solo en modo cliente/outbound)
# Nota: El relay público (magnumsmaster) NO debe usar UPnP - usa port forwarding manual
ENABLE_UPNP=true

# 🏷️ Identificación del Nodo (opcional)
NODE_NAME=Example_Secondary_Node

# 🚀 Modo de Ejecución (opcional)
NODE_ENV=development

# 📊 Configuración de Logs (futuro)
# LOG_LEVEL=info
# LOG_FILE=logs/server.log

# 🔐 Configuración de Seguridad (futuro)
# JWT_SECRET=your_jwt_secret_here
# CORS_ORIGIN=http://localhost:3000

# 💾 Base de Datos (futuro)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=blockchain_db

# CSP/CORS dinámico
LOCAL_API=http://localhost:3000
PROD_API=https://*.apps.run-on-seenode.com
PROD_API_HTTP=http://*.apps.run-on-seenode.com