# 🔒 Configuración de Seguridad NPM

# ✅ Usar solo registry oficial de npm
registry=https://registry.npmjs.org/

# 🔐 Requerir autenticación para paquetes privados
always-auth=false

# 🛡️ Verificar integridad de paquetes
package-lock=true
package-lock-only=false

# 🚫 No permitir actualizaciones automáticas de dependencias
save-exact=true

# 🔍 Auditoría automática al instalar
audit-level=moderate

# 📊 No enviar métricas de uso a npm
send-metrics=false

# 🚨 Configuraciones de seguridad adicionales
fund=false

# 🔒 Verificar firmas de paquetes
verify-store-integrity=true

# ⚠️ Configuración para evitar ataques de typosquatting
prefer-online=false