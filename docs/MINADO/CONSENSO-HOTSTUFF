## 🧪 Ejemplo de módulo `ConsensusEngine`  
**Example of `ConsensusEngine` module**

```typescript
// consensusEngine.ts

type Block = {
  id: string;
  parentId: string;
  data: TraceableAction;
  proposer: string;
  timestamp: number;
};

type Vote = {
  blockId: string;
  voter: string;
  signature: string;
};

type QuorumCertificate = {
  blockId: string;
  votes: Vote[];
};

class ConsensusEngine {
  private currentBlock: Block | null = null;
  private pendingVotes: Map<string, Vote[]> = new Map();

  proposeBlock(data: TraceableAction, proposer: string): Block {
    const newBlock: Block = {
      id: generateUniqueId(),
      parentId: this.currentBlock?.id || "GENESIS",
      data,
      proposer,
      timestamp: Date.now()
    };
    this.currentBlock = newBlock;
    broadcastToValidators(newBlock);
    return newBlock;
  }

  receiveVote(vote: Vote): void {
    const votes = this.pendingVotes.get(vote.blockId) || [];
    votes.push(vote);
    this.pendingVotes.set(vote.blockId, votes);

    if (votes.length >= getQuorumThreshold()) {
      const qc: QuorumCertificate = {
        blockId: vote.blockId,
        votes
      };
      this.commitBlock(qc);
    }
  }

  commitBlock(qc: QuorumCertificate): void {
    const block = fetchBlockById(qc.blockId);
    if (block) {
      persistBlock(block);
      logTraceableEvent(block.data);
      this.currentBlock = block;
    }
  }
}
