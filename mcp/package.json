{
  "name": "large-magnum-master-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Large Magnum Master blockchain - Wine industry traceability",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test/test-mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "blockchain",
    "wine",
    "cartography",
    "ai",
    "traceability",
    "terroir"
  ],
  "author": "Large Magnum Master Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maestroGit/magnumsmaster.git"
  },
  "mcp": {
    "description": "Permite a modelos de IA interactuar con el ecosistema blockchain de trazabilidad vitivinícola",
    "capabilities": [
      "blockchain-query",
      "transaction-creation",
      "network-monitoring",
      "geographic-analysis",
      "log-analysis",
      "predictive-analytics"
    ]
  }
